# --- Database ---
# Standard Postgres connection string (used by the @prisma/adapter-pg driver adapter).
# Prisma Postgres pooled/direct URL example:
DATABASE_URL="postgres://<user>:<password>@<host>:5432/postgres?sslmode=require"

# --- API ---
API_PORT=4000
NODE_ENV=development
# CORS: the web app origin allowed to hit the API
WEB_ORIGIN="http://localhost:3000"

# --- Sessions ---
# 32+ byte random string. Generate: openssl rand -hex 32
SESSION_SECRET="change-me-in-production"
SESSION_TTL_HOURS=24
REMEMBER_ME_SESSION_TTL_HOURS=168
COOKIE_SECURE=false

# --- Account safety ---
# Lock an account after this many consecutive failed logins, for this many minutes.
MAX_FAILED_LOGINS=5
ACCOUNT_LOCK_MINUTES=15
# How long a password-reset token stays valid.
PASSWORD_RESET_TTL_MINUTES=30

# --- Web (Next.js) ---
NEXT_PUBLIC_API_URL="http://localhost:4000"
